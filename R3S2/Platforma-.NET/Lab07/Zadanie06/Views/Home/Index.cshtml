@model IReadOnlyList<Zadanie06.Models.NewsItem>
@{
    ViewData["Title"] = "Aktualności";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Aktualności</h1>
    <a asp-controller="Admin" asp-action="Login" class="btn btn-outline-secondary btn-sm">Panel administratora</a>
</div>
<hr />

@if (!Model.Any())
{
    <p class="text-muted">Brak aktualności.</p>
}
else
{
    foreach (var item in Model)
    {
        <article class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@item.Title</h5>
                <p class="card-text">@item.Content</p>
                <small class="text-muted">Opublikowano: @item.PublishedAt.ToString("dd.MM.yyyy HH:mm")</small>
            </div>
        </article>
    }
}
