<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Zadanie_07.MainPage"
             Title="Kodery i dekodery obrazow 2D">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="0">

            <!-- Tab buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                <Button x:Name="BtnEncoders" Text="Enkodery" FontSize="14"
                        BackgroundColor="RoyalBlue" TextColor="White" CornerRadius="0"
                        Grid.Column="0" Clicked="OnShowEncoders" />
                <Button x:Name="BtnDecoders" Text="Dekodery" FontSize="14"
                        BackgroundColor="Gray" TextColor="White" CornerRadius="0"
                        Grid.Column="1" Clicked="OnShowDecoders" />
            </Grid>

            <!-- Encoder list -->
            <CollectionView x:Name="EncoderList" SelectionMode="Single"
                            HeightRequest="220" SelectionChanged="OnCodecSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" Padding="10,8" />
                            <Label Text="{Binding Extensions}" FontSize="11" TextColor="Gray" Padding="10,0,10,8" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Decoder list -->
            <CollectionView x:Name="DecoderList" SelectionMode="Single"
                            HeightRequest="220" IsVisible="False"
                            SelectionChanged="OnCodecSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" Padding="10,8" />
                            <Label Text="{Binding Extensions}" FontSize="11" TextColor="Gray" Padding="10,0,10,8" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Details -->
            <Frame Padding="0" CornerRadius="8" HasShadow="False" BorderColor="LightGray" Margin="0,10,0,0">
                <Label x:Name="DetailsLabel" FontSize="13" FontFamily="Courier New"
                       Padding="15" BackgroundColor="WhiteSmoke" TextColor="DarkSlateGray"
                       Text="Wybierz kodek z listy, aby zobaczyc szczegoly." />
            </Frame>

            <Label x:Name="InfoBar" FontSize="12" HorizontalTextAlignment="Center"
                   TextColor="Gray" Margin="0,10" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
