<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Zadanie_02.MainPage"
             Title="Operacje arytmetyczne">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="5">

            <Label Text="Argument A:" FontSize="16" />
            <Entry x:Name="EntryA" Keyboard="Numeric" Placeholder="Wprowadz liczbe" FontSize="16" />

            <Label Text="Argument B:" FontSize="16" Margin="0,10,0,0" />
            <Entry x:Name="EntryB" Keyboard="Numeric" Placeholder="Wprowadz liczbe" FontSize="16" />

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,15">
                <Button Text="+" FontSize="24" FontAttributes="Bold"
                        BackgroundColor="RoyalBlue" TextColor="White" CornerRadius="8"
                        HeightRequest="55" Clicked="OnAdd" Grid.Column="0" />
                <Button Text="-" FontSize="24" FontAttributes="Bold"
                        BackgroundColor="SteelBlue" TextColor="White" CornerRadius="8"
                        HeightRequest="55" Clicked="OnSub" Grid.Column="1" />
                <Button Text="*" FontSize="24" FontAttributes="Bold"
                        BackgroundColor="SlateBlue" TextColor="White" CornerRadius="8"
                        HeightRequest="55" Clicked="OnMul" Grid.Column="2" />
                <Button Text="/" FontSize="24" FontAttributes="Bold"
                        BackgroundColor="MediumSlateBlue" TextColor="White" CornerRadius="8"
                        HeightRequest="55" Clicked="OnDiv" Grid.Column="3" />
            </Grid>

            <Label Text="Wynik:" FontSize="16" Margin="0,5,0,0" />
            <Label x:Name="ResultLabel"
                   FontSize="28" FontAttributes="Bold" TextColor="DarkBlue"
                   HorizontalTextAlignment="Center" Padding="10" BackgroundColor="WhiteSmoke" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
